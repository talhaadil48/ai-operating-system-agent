# ─────────────────────────────────────────────
# AI OS — Environment Variables Example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────
# Which backend to use: "groq" | "ollama" | "gemini"
LLM_PROVIDER=groq

# ── Groq (Recommended) ───────────────────────
# Get free API keys at: https://console.groq.com
# Add up to 3 keys — the system tries them in order (1 → 2 → 3).
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_1=your_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_key_here
GROQ_API_KEY_3=your_third_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# ── Groq Vision Model (for screen analysis tool) ─
# Must support image inputs. Check: https://console.groq.com/docs/models
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Gemini (Last-Resort Fallback) ────────────
# Get a free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.3

# ── Ollama (Local Models) ────────────────────
# Only used if LLM_PROVIDER=ollama
# Install Ollama: https://ollama.com
# Then: ollama pull qwen3:8b && ollama serve
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0.3

# ── PostgreSQL — Long-Term Memory ────────────
# Required for persistent long-term memory across sessions.
# Local:  postgresql://postgres:password@localhost:5432/ai_os
# Neon:   postgresql://user:pass@ep-xxx.neon.tech/ai_os?sslmode=require
POSTGRES_URI=postgresql://postgres:password@localhost:5432/ai_os

# ── Web Search ───────────────────────────────
# Get a free key at: https://serper.dev
# Leave blank to disable the web_search tool.
SERPER_API_KEY=your_serper_api_key_here

# ── FastAPI Server ───────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Debugging / Logging ──────────────────────
# Set DEBUG=true to enable verbose logs (full prompts, tool args, timings).
DEBUG=false
# LOG_LEVEL=INFO       # Override log level directly: DEBUG|INFO|WARNING|ERROR
# LOG_JSON=false       # Set to true to emit JSON logs (for Loki/ELK/Datadog)

# ── Memory Tuning ────────────────────────────
# MEMORY_MAX_TURNS=1        # Active conversation turns kept in context window
# LTM_MAX_FACTS=5           # Max long-term memory facts injected per prompt
# LTM_MAX_SUMMARY_WORDS=150 # Max words for LTM prompt block
